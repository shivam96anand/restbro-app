{
  "name": "restbro",
  "version": "1.1.4",
  "description": "A modern API testing tool similar to Postman and Insomnia",
  "main": "dist/main/main/index.js",
  "scripts": {
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p src/main",
    "build:preload": "tsc -p src/preload",
    "build:renderer": "webpack --mode production",
    "dev": "npm run build:main && concurrently \"npm run watch:main\" \"npm run dev:renderer\"",
    "watch:main": "tsc -p src/main --watch",
    "dev:renderer": "webpack serve --mode development",
    "start": "electron .",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "fresh": "npm run rebuild && npm start",
    "dist": "npm run build && electron-builder --mac",
    "dist:mac": "npm run dist",
    "dist:unsigned": "npm run build && electron-builder --mac --config.mac.identity=null",
    "release": "npm run build && electron-builder --mac --publish always",
    "release:mac": "bash scripts/release-mac.sh",
    "release:mac:universal": "bash scripts/release-mac.sh",
    "release:win": "bash scripts/release-win.sh",
    "publish:github": "bash scripts/publish-github-release.sh",
    "ship:mac": "bash scripts/release-mac.sh && bash scripts/publish-github-release.sh",
    "ship:win": "bash scripts/release-win.sh && bash scripts/publish-github-release.sh"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "concurrently": "^8.0.0",
    "css-loader": "^6.8.0",
    "electron": "^26.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.0.0",
    "html-webpack-plugin": "^5.5.0",
    "jsdom": "^29.0.2",
    "monaco-editor-webpack-plugin": "^7.1.1",
    "prettier": "^3.0.0",
    "sass": "^1.66.0",
    "sass-loader": "^13.3.0",
    "style-loader": "^3.3.0",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.1",
    "@codemirror/gutter": "^0.19.9",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.3",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "electron-updater": "^6.8.3",
    "jks-js": "^1.1.6",
    "jsondiffpatch": "^0.5.0",
    "marked": "^12.0.2",
    "monaco-editor": "^0.52.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-window": "^1.8.10"
  },
  "author": "Restbro",
  "license": "MIT",
  "keywords": [
    "api",
    "testing",
    "postman",
    "insomnia",
    "rest",
    "electron"
  ],
  "build": {
    "appId": "com.restbro.app",
    "productName": "Restbro",
    "copyright": "Copyright © 2026 Restbro",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "shivam96anand",
        "repo": "restbro-app"
      }
    ],
    "fileAssociations": [
      {
        "ext": "txt",
        "name": "Plain Text",
        "description": "Plain text document",
        "role": "Editor"
      },
      {
        "ext": "md",
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor"
      },
      {
        "ext": "json",
        "name": "JSON",
        "description": "JSON document",
        "role": "Editor"
      },
      {
        "ext": "log",
        "name": "Log File",
        "description": "Log file",
        "role": "Editor"
      },
      {
        "ext": "yaml",
        "name": "YAML",
        "description": "YAML document",
        "role": "Editor"
      },
      {
        "ext": "yml",
        "name": "YAML",
        "description": "YAML document",
        "role": "Editor"
      },
      {
        "ext": "xml",
        "name": "XML",
        "description": "XML document",
        "role": "Editor"
      },
      {
        "ext": "csv",
        "name": "CSV",
        "description": "Comma-separated values",
        "role": "Editor"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-mac.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": false,
      "strictVerify": false
    },
    "dmg": {
      "sign": false,
      "title": "RestBro",
      "artifactName": "${productName}-${version}.${ext}",
      "background": "build/dmg-background.png",
      "contents": [
        {
          "x": 180,
          "y": 170,
          "type": "file"
        },
        {
          "x": 480,
          "y": 170,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 660,
        "height": 400
      },
      "iconSize": 100
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-win-x64.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "artifactName": "${productName}-${version}-win-x64-setup.${ext}"
    }
  }
}
