{
  "name": "api-courier",
  "version": "1.0.0",
  "description": "A modern API testing tool similar to Postman and Insomnia",
  "main": "dist/main/main/index.js",
  "scripts": {
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p src/main",
    "build:preload": "tsc -p src/preload",
    "build:renderer": "webpack --mode production",
    "dev": "npm run build:main && concurrently \"npm run watch:main\" \"npm run dev:renderer\"",
    "watch:main": "tsc -p src/main --watch",
    "dev:renderer": "webpack serve --mode development",
    "start": "electron .",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "test": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.0.0",
    "css-loader": "^6.8.0",
    "electron": "^26.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "sass": "^1.66.0",
    "sass-loader": "^13.3.0",
    "style-loader": "^3.3.0",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.1",
    "@codemirror/gutter": "^0.19.9",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.3",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "jsondiffpatch": "^0.5.0",
    "monaco-editor": "^0.52.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-window": "^1.8.10"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.0.0",
    "css-loader": "^6.8.0",
    "electron": "^26.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "sass": "^1.66.0",
    "sass-loader": "^13.3.0",
    "style-loader": "^3.3.0",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  },
  "author": "API Courier Team",
  "license": "MIT",
  "keywords": [
    "api",
    "testing",
    "postman",
    "insomnia",
    "rest",
    "electron"
  ]
}
