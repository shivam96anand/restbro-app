{
  "name": "api-courier",
  "version": "1.0.0",
  "description": "A modern API testing tool similar to Postman and Insomnia",
  "main": "dist/main/main/index.js",
  "scripts": {
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p src/main",
    "build:preload": "tsc -p src/preload",
    "build:renderer": "webpack --mode production",
    "dev": "npm run build:main && concurrently \"npm run watch:main\" \"npm run dev:renderer\"",
    "watch:main": "tsc -p src/main --watch",
    "dev:renderer": "webpack serve --mode development",
    "start": "electron .",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "test": "jest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.0.0",
    "css-loader": "^6.8.0",
    "electron": "^26.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "sass": "^1.66.0",
    "sass-loader": "^13.3.0",
    "style-loader": "^3.3.0",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  },
  "dependencies": {},
  "author": "API Courier Team",
  "license": "MIT",
  "keywords": ["api", "testing", "postman", "insomnia", "rest", "electron"]
}