{
  "name": "api-courier",
  "version": "1.0.0",
  "description": "Professional API testing tool - like Postman/Insomnia",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "build:dev": "webpack --config webpack.config.js --mode development",
    "build:watch": "webpack --config webpack.config.js --mode development --watch",
    "start": "npm run build && electron .",
    "dev": "npm run build:dev && electron .",
    "test": "echo \"No test specified\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shivam96anand/api-courier2.0.git"
  },
  "keywords": [
    "api",
    "testing",
    "electron",
    "postman",
    "insomnia"
  ],
  "author": "Shivam Anand",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shivam96anand/api-courier2.0/issues"
  },
  "homepage": "https://github.com/shivam96anand/api-courier2.0#readme",
  "dependencies": {
    "lowdb": "^7.0.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "electron": "^38.0.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.4",
    "mini-css-extract-plugin": "^2.9.4",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "sass": "^1.92.1",
    "sass-loader": "^16.0.5",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.2",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1"
  }
}
